rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == 'lacometta33@gmail.com' && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'admin'])
      );
    }

    function isProjectOwner(projectId) {
      return isAuthenticated() && (
        isAdmin() ||
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
      );
    }

    function isProjectMember(projectId) {
      // For now, members are owners or admins.
      return isProjectOwner(projectId);
    }

    // ===============================================================
    // Global Collections
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Roles
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAdmin(); // Only system/admin can create notifications
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }

    // AI Global Config & Logs
    match /ai/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // AI Task Logs
    match /ai_logs/{logId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
    }

    // Admin Section
    match /admin/{adminDoc} {
      allow read, write: if isAdmin();
      match /{subCollection=**} {
        allow read, write: if isAdmin();
      }
    }

    // Sync States
    match /sync/states/{stateId} {
      allow read, write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid);
    }

    // ===============================================================
    // Project-Scoped Collections
    // ===============================================================
    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerId is string && data.ownerId.size() < 128 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000));
    }

    function isValidFeature(data) {
      return data.keys().hasAll(['title', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['Planned', 'In Progress', 'Completed', 'Archived'] &&
             (!('problem' in data) || (data.problem is string && data.problem.size() < 2000)) &&
             (!('nonTechnicalDescription' in data) || (data.nonTechnicalDescription is string && data.nonTechnicalDescription.size() < 2000));
    }

    function isValidPage(data) {
      return data.keys().hasAll(['name', 'path']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.path is string && data.path.size() < 200;
    }

    function isValidComponent(data) {
      return data.keys().hasAll(['name', 'type']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type is string && data.type.size() < 50;
    }

    function isValidLLMFunction(data) {
      return data.keys().hasAll(['name', 'modelId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.modelId is string && data.modelId.size() < 100;
    }

    match /projects/{projectId} {
      allow get: if isAuthenticated() && (isAdmin() || isProjectMember(projectId));
      allow list: if isAuthenticated() && (
        isAdmin() || 
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.members
      );
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || isProjectOwner(projectId)) && isValidProject(request.resource.data);
      allow delete: if isAdmin() || (isProjectOwner(projectId) && resource.data.name != 'FlowForge AI');

      // Project Settings
      match /settings/config {
        allow read: if isAdmin() || isProjectMember(projectId);
        allow write: if isAdmin() || isProjectOwner(projectId);
      }

      // AI Function Overrides
      match /ai_functions/{functionId} {
        allow read: if isAdmin() || isProjectMember(projectId);
        allow write: if isAdmin() || isProjectOwner(projectId);
      }

      // UI Architecture
      match /ui_pages/{pageId} {
        allow read: if isAdmin() || isProjectMember(projectId);
        allow create: if (isAdmin() || isProjectMember(projectId)) && isValidPage(request.resource.data);
        allow update: if (isAdmin() || isProjectMember(projectId)) && isValidPage(request.resource.data);
        allow delete: if isAdmin() || isProjectMember(projectId);
      }
      
      match /ui_components/{componentId} {
        allow read: if isAdmin() || isProjectMember(projectId);
        allow create: if (isAdmin() || isProjectMember(projectId)) && isValidComponent(request.resource.data);
        allow update: if (isAdmin() || isProjectMember(projectId)) && isValidComponent(request.resource.data);
        allow delete: if isAdmin() || isProjectMember(projectId);
      }

      match /features/{featureId} {
        allow read: if isAdmin() || isProjectMember(projectId);
        allow create: if (isAdmin() || isProjectMember(projectId)) && isValidFeature(request.resource.data);
        allow update: if (isAdmin() || isProjectMember(projectId)) && isValidFeature(request.resource.data);
        allow delete: if isAdmin() || isProjectMember(projectId);
      }

      // Catch-all for other subcollections
      match /{allSubcollections=**} {
        allow read, write: if isAdmin() || isProjectMember(projectId);
      }
    }
  }
}
