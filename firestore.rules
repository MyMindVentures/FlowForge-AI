rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == 'lacometta33@gmail.com' && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'admin'])
      );
    }

    function isProjectOwner(projectId) {
      return isAuthenticated() && (
        isAdmin() ||
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
      );
    }

    function isProjectMember(projectId) {
      // For now, members are owners or admins.
      return isProjectOwner(projectId);
    }

    // ===============================================================
    // Global Collections
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // Roles
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAdmin(); // Only system/admin can create notifications
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
    }

    // AI Global Config & Logs
    match /ai/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // AI Task Logs
    match /ai_logs/{logId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isAdmin();
    }

    // Admin Section
    match /admin/{adminDoc} {
      allow read, write: if isAdmin();
      match /{subCollection=**} {
        allow read, write: if isAdmin();
      }
    }

    // Sync States
    match /sync/states/{stateId} {
      allow read, write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid);
    }

    // ===============================================================
    // Project-Scoped Collections
    // ===============================================================

    match /projects/{projectId} {
      allow get: if isProjectMember(projectId);
      allow list: if isAuthenticated() && (
        isAdmin() || 
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.members
      );
      allow create: if isAuthenticated();
      allow update: if isProjectOwner(projectId);
      allow delete: if isProjectOwner(projectId) && resource.data.name != 'FlowForge AI';

      // Project Settings
      match /settings/config {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectOwner(projectId);
      }

      // AI Function Overrides
      match /ai_functions/{functionId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectOwner(projectId);
      }

      // Ideation Sessions
      match /sessions/{sessionId} {
        allow read, write: if isProjectMember(projectId);
      }

      // Ideation Chats
      match /chats/{chatId} {
        allow read, write: if isProjectMember(projectId);
      }

      // AI Suggestions
      match /suggestions/{suggestionId} {
        allow read, write: if isProjectMember(projectId);
      }

      // Specifications
      match /specifications/{specId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectOwner(projectId);
      }

      // Modules
      match /modules/{moduleId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectOwner(projectId);
      }

      // Roadmap / Versions
      match /roadmap/{versionId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectOwner(projectId);
      }

      match /versions/{versionId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectOwner(projectId);
      }

      // Features
      match /features/{featureId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectMember(projectId);

        // Comments
        match /comments/{commentId} {
          allow read: if isProjectMember(projectId);
          allow create: if isProjectMember(projectId);
          allow update, delete: if isOwner(resource.data.userId);
        }

        // Activity
        match /activity/{logId} {
          allow read: if isProjectMember(projectId);
          allow create: if isProjectMember(projectId);
        }
      }

      // Documents
      match /documents/{docId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectMember(projectId);

        match /versions/{versionId} {
          allow read: if isProjectMember(projectId);
          allow create: if isProjectMember(projectId);
        }
      }

      // Showcase
      match /showcase/{contentId} {
        allow read: if resource.data.isPublic == true || isProjectMember(projectId);
        allow write: if isProjectOwner(projectId);
      }

      // Assets
      match /assets/{assetId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectMember(projectId);
      }

      // Audit Logs
      match /audit_logs/{logId} {
        allow read: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId);
      }

      // AI Logs (Project-specific)
      match /ai_logs/{logId} {
        allow read: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId);
        allow update: if isProjectMember(projectId);
      }

      // AI Generations (Project-specific)
      match /generations/{genId} {
        allow read: if isProjectMember(projectId);
        allow write: if isProjectMember(projectId);
      }

      // UI Architecture
      match /ui_pages/{pageId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /ui_page_visuals/{visualId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /ui_page_docs/{docId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /ui_components/{componentId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /ui_layouts/{layoutId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /ui_style/{configId} {
        allow read, write: if isProjectMember(projectId);
      }

      // Structured Project Data
      match /prd_sections/{sectionId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /audit_findings/{findingId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /readiness_checks/{checkId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /blockers/{blockerId} {
        allow read, write: if isProjectMember(projectId);
      }
      match /tasks/{taskId} {
        allow read, write: if isProjectMember(projectId);
      }
    }
  }
}
